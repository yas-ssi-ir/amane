# ============================================================
# AMANE Mobile — Variables d'environnement Expo (template)
# Copiez ce fichier en .env et remplissez les vraies valeurs.
# NE JAMAIS committer le fichier .env avec de vraies clés.
# ============================================================

# URL du backend FastAPI
EXPO_PUBLIC_API_URL=http://localhost:8000

# Clé Gemini pour l'assistant IA (optionnel côté mobile)
EXPO_PUBLIC_GEMINI_API_KEY=CHANGE_ME_YOUR_GEMINI_API_KEY
